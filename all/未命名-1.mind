{"root":{"data":{"id":"dhusbkm4ze80","created":1776363540088,"text":"AI场景"},"children":[{"data":{"id":"dhuscs1a2hc0","created":1776363634605,"text":"AI拍照识图购件"},"children":[{"data":{"id":"dhusd6cczl40","created":1776363665750,"text":"客户对整机和零件进行拍照，AI识别零件型号和物料号，自助查询当前库存，价格以及替代件","resource":["解决客户/销售不认识零件号，减少人工查件"]},"children":[]}]},{"data":{"id":"dhusfhgpt9k0","created":1776363846686,"text":"AI仓库拍照找件","layout_mind_offset":{"x":477,"y":119}},"children":[{"data":{"id":"dhusg63gdbc0","created":1776363900304,"text":"仓库管理员拍零件或者标签，自动显示库位，库存，库龄"},"children":[]}]}]},"template":"default","theme":"fresh-blue","version":"1.4.43"}