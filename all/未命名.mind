{"root":{"data":{"id":"di0ql71ocew0","created":1776968011714,"text":"图形推理"},"children":[{"data":{"id":"di0qld1ostc0","created":1776968024775,"text":"元素组成相同，位置规律","layout_mind_offset":{"x":-54,"y":-188}},"children":[{"data":{"id":"di0qllbp2yo0","created":1776968042795,"text":"平移","layout_right_offset":{"x":59,"y":-26},"progress":null,"resource":["方向，步数"],"note":"步数为恒定或递增"},"children":[{"data":{"id":"di0qmrtyfj40","created":1776968135324,"text":"顺时针、逆时针","layout_right_offset":{"x":-10,"y":-6},"note":"优先看行，当行中的黑块数量相同时，考虑平移；不同时，考虑样式规律"},"children":[]},{"data":{"id":"di0qo0x83qo0","created":1776968233477,"text":"内外圈分开看","note":"出现4X4宫格，且内圈或外圈内元素数量一致"},"children":[]}]},{"data":{"id":"di0qlypkvbk0","created":1776968071932,"text":"旋转，翻转","layout_right_offset":{"x":51,"y":-26},"resource":["方向，角度"],"note":"常结合样式，例如旋转后求异"},"children":[]}]},{"data":{"id":"di0qrrbbuv40","created":1776968526018,"text":"元素组成相似，样式规律","layout_mind_offset":{"x":752,"y":0}},"children":[{"data":{"id":"di0qs21odg00","created":1776968549379,"text":"加减同异","layout_right_offset":{"x":1,"y":-19}},"children":[{"data":{"id":"di0qsw5nocw0","created":1776968614923,"text":"相加、相减","layout_right_offset":{"x":7,"y":0}},"children":[]},{"data":{"id":"di0qswjrg0g0","created":1776968615776,"text":"求同，保留相同"},"children":[]},{"data":{"id":"di0qsy454so0","created":1776968619185,"text":"· 求异，保留不同","font-weight":"bold","layout_right_offset":{"x":-2,"y":0}},"children":[]}]},{"data":{"id":"di0qs2u6cyg0","created":1776968551103,"text":"黑白运算","note":"区分位置规律，总黑块数量相同时，有限考虑平移；不同则优先考虑样式规律黑白运算"},"children":[]}]},{"data":{"id":"di0qw8bf1k00","created":1776968876486,"text":"分支主题"},"children":[]}]},"template":"default","theme":"fresh-blue","version":"1.4.43"}